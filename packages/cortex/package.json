{
  "name": "@botcoin/cortex",
  "version": "0.1.0",
  "private": false,
  "description": "Botcoin Core decoder, evaluator, and CLI for the Cortex memory codec.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/validator.js",
  "types": "dist/validator.d.ts",
  "exports": {
    ".": {
      "types": "./dist/validator.d.ts",
      "default": "./dist/validator.js"
    },
    "./validator": {
      "types": "./dist/validator.d.ts",
      "default": "./dist/validator.js"
    },
    "./coordinator": {
      "types": "./dist/coordinator.d.ts",
      "default": "./dist/coordinator.js"
    },
    "./full": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "botcoin-cortex": "dist/cli.js",
    "coretex-replay": "dist/replay-cli.js",
    "coretex-validator-sync": "dist/validator-sync-cli.js",
    "coretex-validator-setup": "dist/validator-setup-cli.js",
    "coretex-scorer-server": "dist/scorer-server-cli.js"
  },
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "node --test --test-reporter=spec ./test/unit/*.test.mjs"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "!scripts/**/__pycache__",
    "!scripts/**/__pycache__/**",
    "!scripts/**/*.pyc",
    "!scripts/**/*.pyo"
  ],
  "engines": {
    "node": ">=20.10"
  }
}
